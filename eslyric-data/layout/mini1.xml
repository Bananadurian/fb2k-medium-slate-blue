<?xml version="1.0" encoding="UTF-8"?>
<layout xmlns="https://github.com/ESLyric/layout"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/ESLyric/layout ./Layout.xsd">
    <panel name="mini1"
           layout="stack"
           orientation="vertical"
           features="1">
        <!-- 优化：删除在垂直 Stack 列中会导致逻辑计算错误的垂�?anchor="vcenter" -->
        <container name="button-panel"
                   layout="stack"
                   orientation="horizontal"
                   justify="end"
                   width="100%"
                   height="6%">
            <!-- 优化：按上一轮规则去除了�?justify="end" 相互冲突�?anchor="left" 属�? -->
            <button name="desktop-lyric"
                    width="20"
                    height="20"
                    margin="10,0,0,0"
                    background="imgs/icon/mic-vocal.png"
                    command="mm://View/ESLyric/Desktop Lyric/Show"
                    visibility="0" />
            <button name="fullscreen"
                    margin="10,0,10,0"
                    width="20"
                    height="20"
                    background="imgs/icon/maximize.png"
                    command="mm://View/ESLyric/Panels/Fullscreen"
                    visibility="0" />
            <button name="floating-lyric"
                    margin="0,2,7,0"
                    width="20"
                    height="20"
                    background="imgs/icon/x.png"
                    command="mm://View/ESLyric/Floating Lyric/Show" />
        </container>
        <!-- 优化：增�?layout="free" 声明，并清理不规范的 % 边距写法 -->
        <container name="top-panel"
                   layout="free"
                   width="auto"
                   height="60%"
                   anchor="center"
                   margin="0,0,0,2%"
                   aspect-ratio="1.0">
            <image width="auto"
                   height="100%"
                   anchor="center"
                   margin="0,0,0,0"
                   aspect-ratio="1.0"
                   background="imgs/mask/bg2-1.png" />
            <!-- 优化：规�?rotate 布尔值为标准�?1 -->
            <albumart width="auto"
                      height="80%"
                      margin="0,0,0,0"
                      aspect-ratio="1.0"
                      follow-background="1"
                      use-stub="true"
                      stub="imgs/mask/default.png"
                      fitness="fill"
                      shadow="1"
                      shadow-color="rgba(0, 0, 0, 0.6)"
                      shadow-intensity="2"
                      mask="imgs/mask/cd1.png"
                      rotate="1"
                      rotate-speed="1" />
        </container>
        <!-- 优化：bottom-panel 删除冗余且冲突的 anchor="vfill" (已有 height="*" 控制空间) -->
        <container name="bottom-panel"
                   layout="stack"
                   orientation="vertical"
                   width="100%"
                   height="*"
                   margin="0,0,0,0"
                   justify="start">
            <!-- 优化：song-info-panel 删除�?Stack 中冗余的 anchor="top" -->
            <container name="song-info-panel"
                       layout="stack"
                       orientation="vertical"
                       width="100%"
                       height="*"
                       margin="2%,0,2%,0">
                <label name="title"
                       width="100%"
                       height="50%"
                       margin="0,0,0,0"
                       caption="%title%"
                       command="cm://Properties"
                       text-align="center"
                       text-color="#fffffe"
                       highlight-color="#b7a2f6"
                       bold="true"
                       font-size="14"
                       loop="cycle"
                       loop-padding="60"
                       nowrap="1" />
                <label name="artist"
                       width="100%"
                       height="40%"
                       margin="0,0,0,0"
                       caption="[%artist%]"
                       command="mm://View/Popup panels/Show/SMP-艺人资料"
                       text-align="center"
                       text-color="rgba(200,200,200,0.8)"
                       highlight-color="#b7a2f6"
                       font-size="12"
                       loop="cycle"
                       loop-padding="60"
                       hide-empty="1" />
            </container>
            <!-- 优化：使�?height="*" 完美填充剩余空白区域，并删除冗余�?anchor="fill" -->
            <lyric width="100%"
                   height="*"
                   margin="2%,2%,2%,2%"
                   text-align="center"
                   banner-text="XRE's Music"
                   visibility="0" />
            <!-- 优化：删除在垂直 Stack 列中会导致逻辑计算错误的垂�?anchor="vcenter" -->
            <container name="button-panel"
                       layout="stack"
                       orientation="horizontal"
                       justify="middle"
                       width="100%"
                       height="40%"
                       margin="0,0,0,20%">
                <!-- 优化：按上一轮规则去除了�?justify="end" 相互冲突�?anchor="left" 属�? -->
                <button name="previous-btn"
                        width="40"
                        height="40"
                        margin="0,0,0,0"
                        background="imgs/icon/previous.png"
                        command="esl://Previous" />
                <button name="play-pause-btn"
                        margin="10,0,10,0"
                        width="45"
                        height="45"
                        background="$if($or($not(%isplaying%), %ispaused%),imgs/icon/circle-play.png,imgs/icon/circle-pause.png)"
                        command="esl://PlayOrPause" />
                <button name="next-btn"
                        margin="0,0,0,0"
                        width="40"
                        height="40"
                        background="imgs/icon/next.png"
                        command="esl://Next" />
            </container>
        </container>
    </panel>
</layout>